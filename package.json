{
  "name": "repair-hub-e2e-tests",
  "version": "1.0.0",
  "description": "E2E API test suite for RepairHub Phase 1",
  "scripts": {
    "test": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit",

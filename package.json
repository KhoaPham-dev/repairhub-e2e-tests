    "test:branches": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/02-branches.test.js",
    "test:customers": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/03-customers.test.js",
    "test:orders": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/04-orders.test.js",
    "test:warranty": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/05-warranty.test.js",
    "test:users": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/06-users-rbac.test.js",
    "test:backup": "node --experimental-vm-modules node_modules/.bin/jest --runInBand --forceExit tests/07-backup.test.js",
